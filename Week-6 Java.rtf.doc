Task-8:\par
\par
class Solution \{\par
    public int strStr(String haystack, String needle) \{\par
        int haylength=haystack.length();\par
        int needlelength=needle.length();\par
        if(haylength<needlelength)\par
            return -1;\par
        for(int i=0;i<=haystack.length()-needle.length();i++)\{\par
            int j=0;\par
            while(j<needle.length() && haystack.charAt(i+j)==needle.charAt(j))\par
                j++;\par
            if(j==needle.length())\{\par
                return i;\par
            \}\par
        \}\par
        return -1;\par
    \}\par
\}\par
