Task-6:\par
\par
class Solution \{\par
    public List<Integer> findAnagrams(String s, String p) \{\par
        List<Integer> res = new ArrayList<>();\par
        if (s.length() < p.length())\par
            return res;\par
        int[] sCount = new int[26];\par
        int[] pCount = new int[26];\par
        for (int i = 0; i < p.length(); i++) \{\par
            sCount[s.charAt(i) - 'a']++;\par
            pCount[p.charAt(i) - 'a']++;\par
        \}\par
        if (Arrays.equals(pCount, sCount))\par
            res.add(0);\par
        for (int i = p.length(); i < s.length(); i++) \{\par
            sCount[s.charAt(i) - 'a']++;\par
            // remove character freqeuency which is at i-p.length index bczz its not needed anymore in current window\par
            sCount[s.charAt(i - p.length()) - 'a']--;\par
            if (Arrays.equals(pCount, sCount))\par
                res.add(i - p.length() + 1);\par
        \}\par
        return res;\par
    \}\par
\}\par
