Task-10:\par
\par
import java.util.*;\par
public class Solution \{\par
    // Function to find longest palindrome in substring [start, start+n-1]\par
    static int longestPalindrome(String s, int start, int n) \{\par
        int maxLen = 1;\par
        for (int center = start; center < start + n; center++) \{\par
            // Odd length palindrome\par
            int left = center, right = center;\par
            while (left >= start && right < start + n &&\par
                    s.charAt(left) == s.charAt(right)) \{\par
                maxLen = Math.max(maxLen, right - left + 1);\par
                left--;\par
                right++;\par
            \}\par
            // Even length palindrome\par
            left = center;\par
            right = center + 1;\par
            while (left >= start && right < start + n &&\par
                    s.charAt(left) == s.charAt(right)) \{\par
                maxLen = Math.max(maxLen, right - left + 1);\par
                left--;\par
                right++;\par
            \}\par
        \}\par
        return maxLen;\par
    \}\par
    public static void main(String[] args) \{\par
        Scanner sc = new Scanner(System.in);\par
        int n = sc.nextInt();\par
        String s = sc.next();\par
        String t = s + s; // double string\par
        for (int i = 0; i < n; i++) \{\par
            System.out.println(longestPalindrome(t, i, n));\par
        \}\par
    \}\par
\}\par
\par
\par
}
