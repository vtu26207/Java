import java.util.*;\par
public class Solution\par
 \{\par
  public static long stringSimilarity(String s) \{\par
        int n = s.length();\par
        int[] z = new int[n];\par
        int left = 0, right = 0;\par
        for (int i = 1; i < n; i++) \{\par
            if (i <= right) \{\par
                z[i] = Math.min(right - i + 1, z[i - left]);\par
            \}\par
            while (i + z[i] < n && s.charAt(z[i]) == s.charAt(i + z[i])) \{\par
                z[i]++;\par
            \}\par
            if (i + z[i] - 1 > right) \{\par
                left = i;\par
                right = i + z[i] - 1;\par
            \}\par
        \}\par
        long sum = n; // include full string match\par
        for (int i = 0; i < n; i++) \{\par
            sum += z[i];\par
        \}\par
        return sum;\par
    \}\par
    public static void main(String[] args) \{\par
        Scanner sc = new Scanner(System.in);\par
        int t = sc.nextInt();\par
        sc.nextLine(); // consume newline\par
        while (t-- > 0) \{\par
            String s = sc.nextLine();\par
            System.out.println(stringSimilarity(s));\par
        \}\par
        sc.close();\par
    \}\par
\}\par
