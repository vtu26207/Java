Task-7:\par
\par
import java.util.*;\par
public class Solution \{\par
    // Helper function to check palindrome\par
    static boolean isPalindrome(String s, int left, int right) \{\par
        while (left < right) \{\par
            if (s.charAt(left) != s.charAt(right)) \{\par
                return false;\par
            \}\par
            left++;\par
            right--;\par
        \}\par
        return true;\par
    \}\par
    // Main function\par
    static int palindromeIndex(String s) \{\par
        int left = 0;\par
        int right = s.length() - 1;\par
        while (left < right) \{\par
            if (s.charAt(left) != s.charAt(right)) \{\par
                // Check by removing left character\par
                if (isPalindrome(s, left + 1, right)) \{\par
                    return left;\par
                \}\par
                // Check by removing right character\par
                else if (isPalindrome(s, left, right - 1)) \{\par
                    return right;\par
                \}\par
                else \{\par
                    return -1;\par
                \}\par
            \}\par
            left++;\par
            right--;\par
        \}\par
        return -1; // already palindrome\par
    \}\par
    public static void main(String[] args) \{\par
        Scanner sc = new Scanner(System.in);\par
        int q = sc.nextInt(); // number of test cases\par
        sc.nextLine(); // consume newline\par
        while (q-- > 0) \{\par
            String s = sc.nextLine();\par
            System.out.println(palindromeIndex(s));\par
        \}\par
    \}\par
\}\par
