Task-5:\par
\par
import java.util.*;\par
public class Solution \{\par
    public static int marsExploration(String s) \{\par
        int count = 0;\par
        for (int i = 0; i < s.length(); i++) \{\par
            if (i % 3 == 0 || i % 3 == 2) \{\par
                if (s.charAt(i) != 'S') \{\par
                    count++;\par
                \}\par
            \} else \{ // i % 3 == 1\par
                if (s.charAt(i) != 'O') \{\par
                    count++;\par
                \}\par
            \}\par
        \}\par
        return count;\par
    \}\par
    public static void main(String[] args) \{\par
        Scanner sc = new Scanner(System.in);\par
        String s = sc.nextLine();\par
        System.out.println(marsExploration(s));\par
        sc.close();\par
    \}\par
\}\par
