Task-9:\par
\par
public class Solution \{\par
private int lo, maxLen;\par
public String longestPalindrome(String s) \{\par
\tab int len = s.length();\par
\tab if (len < 2)\par
\tab\tab return s;\tab\par
    for (int i = 0; i < len-1; i++) \{\par
     \tab extendPalindrome(s, i, i);  //assume odd length, try to extend Palindrome as possible\par
     \tab extendPalindrome(s, i, i+1); //assume even length.\par
    \}\par
    return s.substring(lo, lo + maxLen);\par
\}\par
private void extendPalindrome(String s, int j, int k) \{\par
\tab while (j >= 0 && k < s.length() && s.charAt(j) == s.charAt(k)) \{\par
\tab\tab j--;\par
\tab\tab k++;\par
\tab\}\par
\tab if (maxLen < k - j - 1) \{\par
\tab\tab lo = j + 1;\par
\tab\tab maxLen = k - j - 1;\par
\tab\}\par
\}\}\par
