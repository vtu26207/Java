Task-2:\par
\par
public class Solution \{\par
    public boolean repeatedSubstringPattern(String s) \{\par
        int n = s.length();\par
        for (int i = 1; i <= n / 2; i++) \{\par
            if (n % i == 0) \{\par
                String substring = s.substring(0, i);\par
                StringBuilder repeated = new StringBuilder();\par
                for (int j = 0; j < n / i; j++) \{\par
                    repeated.append(substring);\par
                \}\par
                if (repeated.toString().equals(s)) return true;\par
            \}\par
        \}\par
        return false;\par
    \}\par
\}\par
