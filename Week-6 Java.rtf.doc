Task-3:\par
\par
import java.util.*;\par
public class Solution \{\par
    public static String twoStrings(String s1, String s2) \{\par
        HashSet<Character> set = new HashSet<Character>();\par
        // Store characters of s1\par
        for (int i = 0; i < s1.length(); i++) \{\par
            set.add(s1.charAt(i));\par
        \}\par
        // Check if any character of s2 exists in s1\par
        for (int i = 0; i < s2.length(); i++) \{\par
            if (set.contains(s2.charAt(i))) \{\par
                return "YES";\par
            \}\par
        \}\par
        return "NO";\par
    \}\par
    public static void main(String[] args) \{\par
        Scanner sc = new Scanner(System.in);\par
        int t = sc.nextInt();\par
        sc.nextLine();\par
        while (t-- > 0) \{\par
            String s1 = sc.nextLine();\par
            String s2 = sc.nextLine();\par
            System.out.println(twoStrings(s1, s2));\par
        \}\par
        sc.close();\par
    \}\par
\}\par
